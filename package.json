{
  "name": "jamroom-booking",
  "version": "1.0.0",
  "description": "Production-ready JamRoom Rental Booking Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "catalog:realign": "node scripts/catalog/realignBookingCatalog.js",
    "catalog:realign:apply": "node scripts/catalog/realignBookingCatalog.js --apply",
    "catalog:sound:preview": "node scripts/catalog/applySoundEquipmentCatalog.js",
    "catalog:sound:apply": "node scripts/catalog/applySoundEquipmentCatalog.js --apply",
    "catalog:backup": "node scripts/catalog/exportAdminSettingsCatalog.js",
    "catalog:restore:preview": "node scripts/catalog/restoreAdminSettingsCatalog.js",
    "catalog:restore:apply": "node scripts/catalog/restoreAdminSettingsCatalog.js --apply",
    "bookings:rental-types:preview": "node scripts/db/backfillBookingRentalTypes.js",
    "bookings:rental-types:apply": "node scripts/db/backfillBookingRentalTypes.js --apply",
    "cleanup:test-users": "node scripts/setup/deleteTestUsers.js",
    "cleanup:test-users:apply": "node scripts/setup/deleteTestUsers.js --apply"
  },
  "keywords": [
    "jamroom",
    "booking",
    "rental"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sparticuz/chromium": "^143.0.4",
    "@touch4it/ical-timezones": "^1.9.0",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fs": "^0.0.1-security",
    "html2canvas": "^1.4.1",
    "ical-generator": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.0.0",
    "mongodb": "^7.0.0",
    "mongoose": "^7.6.5",
    "nodemailer": "^6.9.7",
    "path": "^0.12.7",
    "puppeteer": "^24.36.0",
    "twilio": "^5.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
